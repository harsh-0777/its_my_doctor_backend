# ─────────────────────────────────────────────────────────────────────────────
# MediBook Backend — .gitignore
# Stack: Node.js, Express, MongoDB (Mongoose), ES Modules
# ─────────────────────────────────────────────────────────────────────────────

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Environment variables (contains DB URI, JWT secrets, SMTP password) ───────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
# .env.example is intentionally NOT ignored — commit it with placeholder values only

# ── Logs (Winston writes to logs/ in production) ──────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Test / Coverage ───────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov

# ── SSL / Key files ───────────────────────────────────────────────────────────
*.pem
*.key
*.p12
*.pfx
*.crt

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.sw?
